# Copy to .env for local development.
# EAS builds do NOT read .env — set these with `eas env:create` instead
# (EXPO_PUBLIC_* vars are inlined into the JS bundle at build time).

# Clerk publishable key (Dashboard → API Keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend API base URL (rotom-services API)
EXPO_PUBLIC_API_URL=http://localhost:3001

# RevenueCat public SDK keys (Project Settings → API Keys, one per platform)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
