{
  "expo": {
    "name": "River AI",
    "slug": "river-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "riverai",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/apple-icon.icon",
      "bundleIdentifier": "com.riverai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "River AI uses the camera to scan and identify your trading cards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.riverai.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 151,
          "android": {
            "image": "./assets/images/splash-logo.png",
            "imageWidth": 151
          }
        }
      ],
      "expo-image",
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "expo-status-bar",
      "expo-web-browser",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
