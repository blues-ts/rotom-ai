{
  "expo": {
    "name": "River AI TCG",
    "slug": "river-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "riverai",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/apple-icon.icon",
      "bundleIdentifier": "com.riverai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "River AI TCG uses the camera to scan and identify your trading cards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.riverai.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E2A47",
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 151,
          "android": {
            "image": "./assets/images/splash-logo.png",
            "imageWidth": 151
          }
        }
      ],
      "expo-image",
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "expo-status-bar",
      "expo-web-browser",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "120ecc67-cc27-4c2b-b22d-3217fd621b26"
      }
    }
  }
}
