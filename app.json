{
  "expo": {
    "name": "River AI TCG",
    "slug": "river-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "riverai",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/apple-icon.icon",
      "bundleIdentifier": "com.riverai.app",
      "associatedDomains": ["applinks:rivertcg.com"],
      "infoPlist": {
        "NSCameraUsageDescription": "River AI TCG uses the camera to scan and identify your trading cards.",
        "NSPhotoLibraryAddUsageDescription": "River AI TCG saves card images to your photo library when you choose Save Image from the share sheet."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F2140",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.riverai.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "Lagoon",
            "ios": "./assets/icons/lagoon.png",
            "android": {
              "foregroundImage": "./assets/icons/lagoon-android-foreground.png",
              "backgroundColor": "#0E3833"
            }
          },
          {
            "name": "Twilight",
            "ios": "./assets/icons/twilight.png",
            "android": {
              "foregroundImage": "./assets/icons/twilight-android-foreground.png",
              "backgroundColor": "#1E1A4A"
            }
          },
          {
            "name": "Sunset",
            "ios": "./assets/icons/sunset.png",
            "android": {
              "foregroundImage": "./assets/icons/sunset-android-foreground.png",
              "backgroundColor": "#40200F"
            }
          },
          {
            "name": "Meadow",
            "ios": "./assets/icons/meadow.png",
            "android": {
              "foregroundImage": "./assets/icons/meadow-android-foreground.png",
              "backgroundColor": "#0E3A22"
            }
          },
          {
            "name": "Rose",
            "ios": "./assets/icons/rose.png",
            "android": {
              "foregroundImage": "./assets/icons/rose-android-foreground.png",
              "backgroundColor": "#401024"
            }
          },
          {
            "name": "Amber",
            "ios": "./assets/icons/amber.png",
            "android": {
              "foregroundImage": "./assets/icons/amber-android-foreground.png",
              "backgroundColor": "#402A0F"
            }
          },
          {
            "name": "Ultra",
            "ios": "./assets/icons/ultra.png",
            "android": {
              "foregroundImage": "./assets/icons/ultra-android-foreground.png",
              "backgroundColor": "#33103F"
            }
          },
          {
            "name": "Glacier",
            "ios": "./assets/icons/glacier.png",
            "android": {
              "foregroundImage": "./assets/icons/glacier-android-foreground.png",
              "backgroundColor": "#1C2A38"
            }
          }
        ]
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E2A47",
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 151,
          "android": {
            "image": "./assets/images/splash-logo.png",
            "imageWidth": 151
          }
        }
      ],
      "expo-image",
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "expo-status-bar",
      "expo-web-browser",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "120ecc67-cc27-4c2b-b22d-3217fd621b26"
      }
    }
  }
}
